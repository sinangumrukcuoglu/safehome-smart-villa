# SafeHome Backend - Environment Variables
# Bu dosyayı .env olarak kopyala ve değerleri doldur

# Sunucu
PORT=3000

# InfluxDB (Time-series database)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influx-token
INFLUX_ORG=safehome
INFLUX_BUCKET=villa_data

# KNX Gateway
KNX_IP=192.168.1.100
KNX_PORT=3671

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/safehome

# JWT Secret
JWT_SECRET=your-secret-key-here
